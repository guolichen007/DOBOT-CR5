# ============================================================
# .gitignore — CR5 ROS1 catkin workspace
# ============================================================

# Catkin generated directories and files
/build/
/devel/
/install/
/log/
/logs/
.catkin_tools/
.catkin_workspace
catkin_workspace
src/CMakeLists.txt

# ROS runtime data
*.bag
*.bag.active
*.db3
*.mcap
*.pcd
*.ply
.ros/

# Large archives and temporary packages
*.zip
*.7z
*.rar
*.tar
*.tar.gz

# Python cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# IDE and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
Desktop.ini

# Logs and temporary files
*.log
*.tmp
*.swp
*~

# Local credentials and secrets
.env
.env.*
!.env.example
*.pem
*.key

# SSH staging (local only, never commit)
.ssh_staging/

# Models and generated inference files
*.engine
*.pt
*.pth
*.onnx
*.plan

# Local logs and editors
cr5_test_logs/
.vscode/
.idea/
*.swp
*~
.DS_Store

# Secrets
*.pem
*.key
id_rsa*
id_ed25519*

# Task prompts (local only)
CLAUDE_DESKTOP_EXECUTION_PROMPT.md
.venv-spray/
build/
devel/
