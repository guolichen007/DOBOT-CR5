<launch>
  <param name="use_sim_time" value="true" />

  <!-- D435 camera topic names (default: D435_camera) -->
  <arg name="camera_name" default="D435_camera" />

  <!-- Input topics from Gazebo simulation (note: /camera/ prefix) -->
  <arg name="rgb_camera_info" value="/$(arg camera_name)/camera/color/camera_info"/>
  <arg name="rgb_img_rect" value="/$(arg camera_name)/camera/color/image_raw"/>
  <arg name="depth_image_raw" value="/$(arg camera_name)/camera/depth/image_raw"/>

  <!-- Output topic (matches plugin config, no camera/ prefix) -->
  <arg name="out_cloud" value="/$(arg camera_name)/depth/color/points"/>

  <!-- Nodelet manager -->
  <node pkg="nodelet" type="nodelet" name="standalone_nodelet" args="manager" output="screen"/>

  <!-- Convert depth from mm (uint16) to meters (float32) -->
  <node pkg="nodelet" type="nodelet" name="convert_metric" args="load depth_image_proc/convert_metric standalone_nodelet">
    <remap from="image_raw" to="$(arg depth_image_raw)"/>
    <remap from="image" to="$(arg camera_name)/depth/image_rect"/>
  </node>

  <!-- Generate XYZRGB point cloud from depth + RGB -->
  <node pkg="nodelet" type="nodelet" name="points_xyzrgb" args="load depth_image_proc/point_cloud_xyzrgb standalone_nodelet --no-bond">
    <remap from="rgb/camera_info" to="$(arg rgb_camera_info)"/>
    <remap from="rgb/image_rect_color" to="$(arg rgb_img_rect)"/>
    <remap from="depth_registered/image_rect" to="$(arg camera_name)/depth/image_rect"/>
    <remap from="depth_registered/points" to="$(arg out_cloud)"/>
  </node>
</launch>
