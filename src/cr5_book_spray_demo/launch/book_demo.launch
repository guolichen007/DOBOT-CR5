<launch>
  <!-- This launch intentionally does NOT start the CR5 driver or MoveIt, to
       avoid duplicate /cr5_robot or /move_group nodes in the existing project. -->
  <arg name="start_camera" default="true"/>
  <arg name="allow_execution" default="false"/>
  <arg name="path_mode" default="single_stroke"/>
  <arg name="orientation_mode" default="keep_current"/>
  <arg name="eef_link" default="Tool_end"/>

  <include file="$(find cr5_book_spray_demo)/launch/vision_only.launch">
    <arg name="start_camera" value="$(arg start_camera)"/>
  </include>

  <include file="$(find cr5_book_spray_demo)/launch/planner_only.launch">
    <arg name="allow_execution" value="$(arg allow_execution)"/>
    <arg name="path_mode" value="$(arg path_mode)"/>
    <arg name="orientation_mode" value="$(arg orientation_mode)"/>
    <arg name="eef_link" value="$(arg eef_link)"/>
  </include>
</launch>
