// CR5 Calibration Target V1 — OGRE Material Scripts (V4: model-local)
// 标定贴图材料：关闭光照、双面渲染、clamp UV、无 mipmap

material CR5/Calibration/CharucoFront
{
  technique
  {
    pass
    {
      cull_hardware none
      cull_software none
      lighting off
      ambient  1.0 1.0 1.0 1.0
      diffuse  1.0 1.0 1.0 1.0
      specular 0.0 0.0 0.0 1.0
      emissive 0.0 0.0 0.0 1.0

      texture_unit
      {
        texture charuco_front_v1.png
        tex_address_mode clamp
        filtering none
      }
    }
  }
}

