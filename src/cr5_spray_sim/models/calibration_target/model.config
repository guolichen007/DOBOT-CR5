<?xml version="1.0"?>
<model>
  <name>Calibration Target</name>
  <version>1.0</version>
  <sdf version="1.7">model.sdf</sdf>

  <author>
    <name>DOBOT CR5 Team</name>
    <email></email>
  </author>

  <description>
    Multi-face calibration target for DOBOT CR5 three-camera system.
    Body: 0.34×0.28×0.24 m.
    Front/Back: ChArUco 8×6 (IDs 100-123, 300-323), 0.24×0.18 m.
    Left: ChArUco 6×5 (IDs 200-214), 0.16×0.12 m.
    Right: AprilTag 36h11 2×2 (IDs 4-7), 0.22×0.18 m.
    Top: AprilTag 36h11 (ID 8), 0.16×0.16 m.
    Asymmetric top block for orientation disambiguation.
  </description>
</model>
