<?xml version="1.0"?>
<!--
  Calibration Target V1: 吊挂式非对称多面标定目标模型 (V2 — 几何修复版)

  V2 修复:
  - 面板 box 尺寸轴直接对应世界轴，不用 rpy 旋转
  - 新增 object_frame root link + identity joint → calibration_target_frame
  - Back panel 使用 CharucoBackV1 (ChArUco 300-323)
  - package.xml gazebo_media_path + GAZEBO_RESOURCE_PATH 确保材质加载

  坐标系 (world-frame 对齐):
    +X: 正面 ChArUco 板外法向 (朝向 CR5)
    +Y: 左侧面
    +Z: 竖直向上

  TF 树:
    world → object_frame → calibration_target_frame
      ├── calibration_target_front_frame
      ├── calibration_target_left_frame
      ├── calibration_target_right_frame
      ├── calibration_target_top_frame
      └── calibration_target_back_frame
-->
<robot name="calibration_target_v1" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ===== 基本参数 (V5) ===== -->
  <xacro:property name="body_sx" value="0.34"/>  <!-- X: 前后 -->
  <xacro:property name="body_sy" value="0.28"/>  <!-- Y: 左右 -->
  <xacro:property name="body_sz" value="0.24"/>  <!-- Z: 上下 -->
  <xacro:property name="panel_gap" value="0.001"/>

  <!-- 面板外表面偏移 (V5: PANEL_GAP 替代 panel_thick/2) -->
  <xacro:property name="front_x" value="${body_sx/2 + panel_gap}"/>
  <xacro:property name="back_x"  value="${-body_sx/2 - panel_gap}"/>
  <xacro:property name="left_y"  value="${body_sy/2 + panel_gap}"/>
  <xacro:property name="right_y" value="${-body_sy/2 - panel_gap}"/>
  <xacro:property name="top_z"   value="${body_sz/2 + panel_gap}"/>

  <!-- 吊具参数 (V5) -->
  <xacro:property name="spreader_z" value="0.62"/>
  <xacro:property name="hanger_y" value="0.115"/>
  <xacro:property name="cable_radius" value="0.003"/>
  <xacro:property name="cable_bottom_z" value="0.12"/>
  <xacro:property name="cable_top_z" value="0.605"/>
  <xacro:property name="cable_len" value="${cable_top_z - cable_bottom_z}"/>
  <xacro:property name="cable_mid_z" value="${(cable_top_z + cable_bottom_z) / 2}"/>

  <!-- ===== 材质 ===== -->
  <material name="body_mat_gray">
    <color rgba="0.55 0.55 0.57 1"/>
  </material>
  <material name="block_mat_orange">
    <color rgba="0.92 0.45 0.08 1"/>
  </material>
  <material name="cable_black">
    <color rgba="0.12 0.12 0.14 1"/>
  </material>
  <material name="bar_gray">
    <color rgba="0.40 0.40 0.42 1"/>
  </material>

  <!-- ========================================================= -->
  <!-- object_frame — 工件坐标系 root (供 object_pose_tf_v31 发布) -->
  <!-- ========================================================= -->
  <link name="object_frame"/>

  <!-- calibration_target_frame — 目标几何中心 (所有面板的父 frame) -->
  <link name="calibration_target_frame"/>

  <joint name="object_to_calibration_target" type="fixed">
    <parent link="object_frame"/>
    <child link="calibration_target_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ========================================================= -->
  <!-- 主体 0.30×0.22×0.18m                                         -->
  <!-- ========================================================= -->
  <link name="main_body">
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.018" iyz="0" izz="0.025"/>
    </inertial>
    <visual name="body_vis">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="${body_sx} ${body_sy} ${body_sz}"/></geometry>
      <material name="body_mat_gray"/>
    </visual>
    <collision name="body_col">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="${body_sx} ${body_sy} ${body_sz}"/></geometry>
    </collision>
  </link>

  <joint name="ct_to_body" type="fixed">
    <parent link="calibration_target_frame"/>
    <child link="main_body"/>
  </joint>

  <!-- ========================================================= -->
  <!-- 顶部偏置块 (非对称特征)                                      -->
  <!-- ========================================================= -->
  <xacro:property name="block_sx" value="0.06"/>  <!-- V5: 缩小 -->
  <xacro:property name="block_sy" value="0.05"/>
  <xacro:property name="block_sz" value="0.04"/>
  <xacro:property name="block_off_x" value="0.13"/>
  <xacro:property name="block_off_y" value="0.11"/>

  <link name="top_offset_block">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.00015" iyz="0" izz="0.0002"/>
    </inertial>
    <visual name="block_vis">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="${block_sx} ${block_sy} ${block_sz}"/></geometry>
      <material name="block_mat_orange"/>
    </visual>
  </link>

  <joint name="ct_to_block" type="fixed">
    <parent link="calibration_target_frame"/>
    <child link="top_offset_block"/>
    <origin xyz="${block_off_x} ${block_off_y} ${body_sz/2 + block_sz/2}" rpy="0 0 0"/>
  </joint>

  <!-- ========================================================= -->
  <!-- Front panel: ChArUco 8×6, Markers 100–123                   -->
  <!-- Box: thickness(X) × 0.24(Y) × 0.18(Z), 贴 +X 面              -->
  <!-- ========================================================= -->
  <link name="front_panel">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00015" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0002"/>
    </inertial>
    <visual name="front_panel_vis">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="${panel_gap} 0.24 0.18"/></geometry>
    </visual>
  </link>

  <joint name="ct_to_front_panel" type="fixed">
    <parent link="calibration_target_frame"/>
    <child link="front_panel"/>
    <origin xyz="${front_x} 0 0" rpy="0 0 0"/>
  </joint>

  <link name="calibration_target_front_frame"/>
  <joint name="front_panel_to_frame" type="fixed">
    <parent link="front_panel"/>
    <child link="calibration_target_front_frame"/>
  </joint>

  <!-- ========================================================= -->
  <!-- Left panel: ChArUco 6×5, Markers 200–214                    -->
  <!-- Box: 0.16(X) × thickness(Y) × 0.12(Z), 贴 +Y 面              -->
  <!-- ========================================================= -->
  <link name="left_panel">
    <inertial>
      <mass value="0.03"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.00015" iyz="0" izz="0.0001"/>
    </inertial>
    <visual name="left_panel_vis">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.16 ${panel_gap} 0.12"/></geometry>
    </visual>
  </link>

  <joint name="ct_to_left_panel" type="fixed">
    <parent link="calibration_target_frame"/>
    <child link="left_panel"/>
    <origin xyz="0 ${left_y} 0" rpy="0 0 0"/>
  </joint>

  <link name="calibration_target_left_frame"/>
  <joint name="left_panel_to_frame" type="fixed">
    <parent link="left_panel"/>
    <child link="calibration_target_left_frame"/>
  </joint>

  <!-- ========================================================= -->
  <!-- Right panel: AprilTag 2×2, IDs 4–7                         -->
  <!-- Box: 0.22(X) × thickness(Y) × 0.18(Z), 贴 -Y 面             -->
  <!-- ========================================================= -->
  <link name="right_panel">
    <inertial>
      <mass value="0.04"/>
      <inertia ixx="0.00015" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.00015"/>
    </inertial>
    <visual name="right_panel_vis">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.22 ${panel_gap} 0.18"/></geometry>
    </visual>
  </link>

  <joint name="ct_to_right_panel" type="fixed">
    <parent link="calibration_target_frame"/>
    <child link="right_panel"/>
    <origin xyz="0 ${right_y} 0" rpy="0 0 0"/>
  </joint>

  <link name="calibration_target_right_frame"/>
  <joint name="right_panel_to_frame" type="fixed">
    <parent link="right_panel"/>
    <child link="calibration_target_right_frame"/>
  </joint>

  <!-- ========================================================= -->
  <!-- Top panel: AprilTag, ID 8, 贴 +Z 面                          -->
  <!-- ========================================================= -->
  <link name="top_panel">
    <inertial>
      <mass value="0.03"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.00005"/>
    </inertial>
    <visual name="top_panel_vis">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.16 0.16 ${panel_gap}"/></geometry>
    </visual>
  </link>

  <joint name="ct_to_top_panel" type="fixed">
    <parent link="calibration_target_frame"/>
    <child link="top_panel"/>
    <origin xyz="0 0 ${top_z}" rpy="0 0 0"/>
  </joint>

  <link name="calibration_target_top_frame"/>
  <joint name="top_panel_to_frame" type="fixed">
    <parent link="top_panel"/>
    <child link="calibration_target_top_frame"/>
  </joint>

  <!-- ========================================================= -->
  <!-- Back panel: ChArUco 300–323, 后相机覆盖, 贴 -X 面            -->
  <!-- ========================================================= -->
  <link name="back_panel">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00015" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0002"/>
    </inertial>
    <visual name="back_panel_vis">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="${panel_gap} 0.24 0.18"/></geometry>
    </visual>
  </link>

  <joint name="ct_to_back_panel" type="fixed">
    <parent link="calibration_target_frame"/>
    <child link="back_panel"/>
    <origin xyz="${back_x} 0 0" rpy="0 0 0"/>
  </joint>

  <link name="calibration_target_back_frame"/>
  <joint name="back_panel_to_frame" type="fixed">
    <parent link="back_panel"/>
    <child link="calibration_target_back_frame"/>
  </joint>

  <!-- ========================================================= -->
  <!-- 吊索 + 横杆                                                  -->
  <!-- ========================================================= -->

  <link name="left_cable">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.00001"/>
    </inertial>
    <visual name="left_cable_vis">
      <origin xyz="0 ${-hanger_y} ${cable_mid_z}" rpy="0 0 0"/>
      <geometry><cylinder radius="${cable_radius}" length="${cable_len}"/></geometry>
      <material name="cable_black"/>
    </visual>
  </link>
  <joint name="ct_to_left_cable" type="fixed">
    <parent link="calibration_target_frame"/>
    <child link="left_cable"/>
  </joint>

  <link name="right_cable">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.00001"/>
    </inertial>
    <visual name="right_cable_vis">
      <origin xyz="0 ${hanger_y} ${cable_mid_z}" rpy="0 0 0"/>
      <geometry><cylinder radius="${cable_radius}" length="${cable_len}"/></geometry>
      <material name="cable_black"/>
    </visual>
  </link>
  <joint name="ct_to_right_cable" type="fixed">
    <parent link="calibration_target_frame"/>
    <child link="right_cable"/>
  </joint>

  <link name="spreader_bar">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.008"/>
    </inertial>
    <visual name="bar_vis">
      <origin xyz="0 0 ${spreader_z}" rpy="0 0 0"/>
      <geometry><box size="0.03 0.30 0.03"/></geometry>
      <material name="bar_gray"/>
    </visual>
    <collision name="bar_col">
      <origin xyz="0 0 ${spreader_z}" rpy="0 0 0"/>
      <geometry><box size="0.03 0.30 0.03"/></geometry>
    </collision>
  </link>
  <joint name="ct_to_spreader" type="fixed">
    <parent link="calibration_target_frame"/>
    <child link="spreader_bar"/>
  </joint>

  <!-- ========================================================= -->
  <!-- Gazebo 配置                                               -->
  <!-- ========================================================= -->
  <gazebo><static>true</static></gazebo>

  <gazebo reference="front_panel">
    <material>CR5/Calibration/CharucoFrontV1</material>
  </gazebo>
  <gazebo reference="left_panel">
    <material>CR5/Calibration/CharucoLeftV1</material>
  </gazebo>
  <gazebo reference="right_panel">
    <material>CR5/Calibration/AprilTagRightV1</material>
  </gazebo>
  <gazebo reference="top_panel">
    <material>CR5/Calibration/AprilTagTopV1</material>
  </gazebo>
  <gazebo reference="back_panel">
    <material>CR5/Calibration/CharucoBackV1</material>
  </gazebo>

</robot>
