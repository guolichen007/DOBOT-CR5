<?xml version="1.0"?>
<!--
  V3.1 Simple Hanging Workpiece: 吊具+吊索+工件合并为一个模型。
  全部使用 URDF primitive (box/cylinder)，不使用任何 STL。

  模型原点 = 工件几何中心。
  旋转整个模型通过 /gazebo/set_model_state。

  工件类型:
    motor_housing_cylinder  — 横向圆柱电机壳体 (默认)
    rectangular_housing     — 矩形箱体

  结构:
    object_frame          — 工件坐标系（原点）
    surface_frame_front   — 朝 CR5 的主喷涂面坐标系
    workpiece_body        — 工件几何
    left_hanger_lug       — 左吊耳
    right_hanger_lug      — 右吊耳
    left_cable            — 左吊索
    right_cable           — 右吊索
    spreader_bar          — 顶部横杆
-->
<robot name="simple_hanging_workpiece" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:arg name="object_type" default="motor_housing_cylinder"/>
  <xacro:property name="type" value="$(arg object_type)"/>

  <!-- ===== 材质 ===== -->
  <material name="body_blue">
    <color rgba="0.10 0.35 0.75 1"/>
  </material>
  <material name="accent_orange">
    <color rgba="0.92 0.45 0.08 1"/>
  </material>
  <material name="endcap_dark_gray">
    <color rgba="0.25 0.25 0.28 1"/>
  </material>
  <material name="cable_black">
    <color rgba="0.12 0.12 0.14 1"/>
  </material>
  <material name="bar_gray">
    <color rgba="0.40 0.40 0.42 1"/>
  </material>

  <!-- ===== 公共吊具结构（两种工件共用） ===== -->

  <!-- 顶部横杆 (spreader bar) -->
  <!-- 位于工件上方约 0.67m，搭在门架顶梁上 -->
  <xacro:property name="spreader_z" value="0.67"/>
  <xacro:property name="spreader_half_y" value="0.15"/>
  <xacro:property name="cable_radius" value="0.003"/>
  <!-- 吊索在工件上的挂点 Y 坐标 -->
  <xacro:property name="hanger_y" value="0.12"/>

  <!-- object_frame: 工件坐标系原点，位于工件几何中心 -->
  <link name="object_frame"/>

  <!-- surface_frame_front: 朝向 CR5（-X 方向）的主喷涂面 -->
  <link name="surface_frame_front"/>
  <joint name="object_to_surface_frame" type="fixed">
    <parent link="object_frame"/>
    <child link="surface_frame_front"/>
    <!-- +Z 指向 CR5 (-X world)，位于工件正面 -->
    <origin xyz="0 0 0" rpy="0 1.5708 0"/>
  </joint>

  <!-- ================================================================
       motor_housing_cylinder: 横向圆柱电机壳体
       圆柱轴沿 Y，总长约 0.44m
       ================================================================ -->
  <xacro:if value="${type == 'motor_housing_cylinder'}">

    <xacro:property name="body_radius" value="0.105"/>
    <xacro:property name="body_len_y" value="0.36"/>
    <xacro:property name="left_cap_len" value="0.035"/>
    <xacro:property name="left_cap_r" value="0.115"/>
    <xacro:property name="right_cap_len" value="0.045"/>
    <xacro:property name="right_cap_r" value="0.115"/>
    <xacro:property name="shaft_len" value="0.055"/>
    <xacro:property name="shaft_r" value="0.040"/>

    <!-- 端盖 Y 位置 -->
    <xacro:property name="left_cap_y" value="-0.1975"/>
    <xacro:property name="right_cap_y" value="0.2025"/>
    <xacro:property name="shaft_y" value="0.2525"/>

    <!-- 吊耳位置：主体圆柱顶部表面 -->
    <xacro:property name="lug_z" value="0.105"/>

    <link name="workpiece_body">
      <inertial>
        <mass value="2.5"/>
        <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.015" iyz="0" izz="0.03"/>
      </inertial>

      <!-- 主体圆柱 (沿 Y 轴) -->
      <visual name="body_cylinder">
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${body_radius}" length="${body_len_y}"/></geometry>
        <material name="body_blue"/>
      </visual>
      <collision name="body_col">
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${body_radius}" length="${body_len_y}"/></geometry>
      </collision>

      <!-- 左端盖 (深灰) -->
      <visual name="left_end_cap">
        <origin xyz="0 ${left_cap_y} 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${left_cap_r}" length="${left_cap_len}"/></geometry>
        <material name="endcap_dark_gray"/>
      </visual>
      <collision name="left_cap_col">
        <origin xyz="0 ${left_cap_y} 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${left_cap_r}" length="${left_cap_len}"/></geometry>
      </collision>

      <!-- 右端盖 (深灰, 比左边稍长) -->
      <visual name="right_end_cap">
        <origin xyz="0 ${right_cap_y} 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${right_cap_r}" length="${right_cap_len}"/></geometry>
        <material name="endcap_dark_gray"/>
      </visual>
      <collision name="right_cap_col">
        <origin xyz="0 ${right_cap_y} 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${right_cap_r}" length="${right_cap_len}"/></geometry>
      </collision>

      <!-- 短轴/法兰 (橙色, 右侧) -->
      <visual name="shaft">
        <origin xyz="0 ${shaft_y} 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${shaft_r}" length="${shaft_len}"/></geometry>
        <material name="accent_orange"/>
      </visual>
      <collision name="shaft_col">
        <origin xyz="0 ${shaft_y} 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${shaft_r}" length="${shaft_len}"/></geometry>
      </collision>

      <!-- 左吊耳 (深灰小方块, 主体顶部) -->
      <visual name="left_lug">
        <origin xyz="0 ${-hanger_y} ${lug_z}" rpy="0 0 0"/>
        <geometry><box size="0.02 0.02 0.015"/></geometry>
        <material name="endcap_dark_gray"/>
      </visual>

      <!-- 右吊耳 -->
      <visual name="right_lug">
        <origin xyz="0 ${hanger_y} ${lug_z}" rpy="0 0 0"/>
        <geometry><box size="0.02 0.02 0.015"/></geometry>
        <material name="endcap_dark_gray"/>
      </visual>

      <!-- 吊索挂点 Z -->
      <xacro:property name="cable_bottom_z" value="${lug_z + 0.008}"/>
    </link>

  </xacro:if>

  <!-- ================================================================
       rectangular_housing: 矩形箱体
       ================================================================ -->
  <xacro:if value="${type == 'rectangular_housing'}">

    <xacro:property name="main_sx" value="0.18"/>
    <xacro:property name="main_sy" value="0.36"/>
    <xacro:property name="main_sz" value="0.26"/>
    <xacro:property name="top_sx" value="0.10"/>
    <xacro:property name="top_sy" value="0.12"/>
    <xacro:property name="top_sz" value="0.07"/>
    <xacro:property name="top_off_y" value="0.07"/>
    <xacro:property name="top_off_z" value="0.165"/>

    <!-- 吊耳位置：主箱体顶部表面 -->
    <xacro:property name="lug_z" value="0.13"/>
    <xacro:property name="cable_bottom_z" value="${lug_z + 0.008}"/>

    <link name="workpiece_body">
      <inertial>
        <mass value="3.0"/>
        <inertia ixx="0.04" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.04"/>
      </inertial>

      <!-- 主箱体 (蓝色) -->
      <visual name="main_box">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><box size="${main_sx} ${main_sy} ${main_sz}"/></geometry>
        <material name="body_blue"/>
      </visual>
      <collision name="main_box_col">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><box size="${main_sx} ${main_sy} ${main_sz}"/></geometry>
      </collision>

      <!-- 顶部接线盒 (橙色, 偏右侧) -->
      <visual name="top_box">
        <origin xyz="0 ${top_off_y} ${top_off_z}" rpy="0 0 0"/>
        <geometry><box size="${top_sx} ${top_sy} ${top_sz}"/></geometry>
        <material name="accent_orange"/>
      </visual>
      <collision name="top_box_col">
        <origin xyz="0 ${top_off_y} ${top_off_z}" rpy="0 0 0"/>
        <geometry><box size="${top_sx} ${top_sy} ${top_sz}"/></geometry>
      </collision>

      <!-- 左吊耳 (深灰小方块, 主箱体顶部) -->
      <visual name="left_lug">
        <origin xyz="0 ${-hanger_y} ${lug_z}" rpy="0 0 0"/>
        <geometry><box size="0.02 0.02 0.015"/></geometry>
        <material name="endcap_dark_gray"/>
      </visual>

      <!-- 右吊耳 -->
      <visual name="right_lug">
        <origin xyz="0 ${hanger_y} ${lug_z}" rpy="0 0 0"/>
        <geometry><box size="0.02 0.02 0.015"/></geometry>
        <material name="endcap_dark_gray"/>
      </visual>
    </link>

  </xacro:if>

  <!-- ===== object_frame → workpiece_body ===== -->
  <joint name="object_to_body" type="fixed">
    <parent link="object_frame"/>
    <child link="workpiece_body"/>
  </joint>

  <!-- ===== 吊索 (cables) ===== -->
  <!-- 左吊索: 从工件左吊耳到顶部横杆左端 -->
  <xacro:property name="cable_len" value="${spreader_z - cable_bottom_z}"/>
  <xacro:property name="cable_mid_z" value="${(spreader_z + cable_bottom_z) / 2}"/>

  <link name="left_cable">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.00001"/>
    </inertial>
    <visual name="left_cable_vis">
      <origin xyz="0 ${-hanger_y} ${cable_mid_z}" rpy="0 0 0"/>
      <geometry><cylinder radius="${cable_radius}" length="${cable_len}"/></geometry>
      <material name="cable_black"/>
    </visual>
  </link>
  <joint name="object_to_left_cable" type="fixed">
    <parent link="object_frame"/>
    <child link="left_cable"/>
  </joint>

  <!-- 右吊索 -->
  <link name="right_cable">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.00001"/>
    </inertial>
    <visual name="right_cable_vis">
      <origin xyz="0 ${hanger_y} ${cable_mid_z}" rpy="0 0 0"/>
      <geometry><cylinder radius="${cable_radius}" length="${cable_len}"/></geometry>
      <material name="cable_black"/>
    </visual>
  </link>
  <joint name="object_to_right_cable" type="fixed">
    <parent link="object_frame"/>
    <child link="right_cable"/>
  </joint>

  <!-- ===== 顶部横杆 (spreader bar) ===== -->
  <!-- 搭在门架顶梁上, 水平方向沿 Y -->
  <link name="spreader_bar">
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.008"/>
    </inertial>
    <visual name="bar_vis">
      <origin xyz="0 0 ${spreader_z}" rpy="0 0 0"/>
      <geometry><box size="0.03 0.30 0.03"/></geometry>
      <material name="bar_gray"/>
    </visual>
    <collision name="bar_col">
      <origin xyz="0 0 ${spreader_z}" rpy="0 0 0"/>
      <geometry><box size="0.03 0.30 0.03"/></geometry>
    </collision>
  </link>
  <joint name="object_to_spreader" type="fixed">
    <parent link="object_frame"/>
    <child link="spreader_bar"/>
  </joint>

  <!-- ===== Gazebo 配置 ===== -->
  <gazebo><static>true</static></gazebo>

</robot>
