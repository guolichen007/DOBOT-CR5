<?xml version="1.0"?>
<!--
  V3.3 Spray Gun Macro: 紧凑型工业自动喷枪（visual-only 第一阶段）。

  与 V3.2 的关键区别:
  - 所有 visual 合并到一个 link (spray_gun_assembly)，不给 Link6 增加独立质量/惯量
  - 只保留 spray_nozzle_frame 作为 TF 参考系
  - 不使用旧 Tool_end 坐标，直接从 Link6 法兰面安装
  - 第一阶段: 零附加质量 (mass=0)，无 collision
  - 第二阶段以后可逐步添加 collision 和 payload mass

  链路:
    Link6 (法兰面)
    → spray_gun_assembly (所有喷枪 visual, mass=0, no collision)
    → spray_nozzle_frame (+Z = 喷射方向, frame only)

  用法:
    <xacro:spray_gun_v33 parent="Link6"
        mount_xyz="0 0 0.010"
        mount_rpy="0 0 0"
        prefix="spray"/>
-->
<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:macro name="spray_gun_v33"
               params="parent
                       mount_xyz := '0 0 0.010'
                       mount_rpy := '0 0 0'
                       prefix := spray">

    <!-- ===== 材质定义 ===== -->
    <material name="${prefix}_Gray">
      <color rgba="0.50 0.50 0.52 1"/>
    </material>
    <material name="${prefix}_Dark">
      <color rgba="0.18 0.20 0.25 1"/>
    </material>
    <material name="${prefix}_Silver">
      <color rgba="0.65 0.63 0.60 1"/>
    </material>
    <material name="${prefix}_Orange">
      <color rgba="0.92 0.45 0.08 1"/>
    </material>
    <material name="${prefix}_Blue">
      <color rgba="0.10 0.35 0.75 1"/>
    </material>

    <!-- ===== 喷枪装配体 (所有 visual 合并在一个 link，零质量) ===== -->
    <link name="${prefix}_gun_assembly">
      <!-- 零质量: 第一阶段不增加 payload -->
      <inertial>
        <mass value="0.0"/>
        <inertia ixx="0.0" ixy="0" ixz="0" iyy="0.0" iyz="0" izz="0.0"/>
      </inertial>

      <!-- (1) 法兰适配板: 圆柱, 贴合 Link6 法兰面 -->
      <visual name="${prefix}_adapter_vis">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><cylinder radius="0.025" length="0.020"/></geometry>
        <material name="${prefix}_Gray"/>
      </visual>

      <!-- (2) 枪体主块: box, Z 方向沿枪身轴线 -->
      <visual name="${prefix}_body_main_vis">
        <origin xyz="0 0 0.0475" rpy="0 0 0"/>
        <geometry><box size="0.050 0.038 0.075"/></geometry>
        <material name="${prefix}_Dark"/>
      </visual>

      <!-- (2b) 阀块: 偏置在枪体 +Y 侧 -->
      <visual name="${prefix}_valve_vis">
        <origin xyz="0 0.030 0.060" rpy="0 0 0"/>
        <geometry><box size="0.030 0.044 0.030"/></geometry>
        <material name="${prefix}_Gray"/>
      </visual>

      <!-- (2c) 涂料接口短管: +Y 方向, 橙色 -->
      <visual name="${prefix}_paint_port_vis">
        <origin xyz="0 0.052 0.060" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.005" length="0.018"/></geometry>
        <material name="${prefix}_Orange"/>
      </visual>

      <!-- (2d) 空气接口短管: -Y 方向, 蓝色 -->
      <visual name="${prefix}_air_port_vis">
        <origin xyz="0 -0.040 0.065" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.004" length="0.014"/></geometry>
        <material name="${prefix}_Blue"/>
      </visual>

      <!-- (3) 喷嘴: 细长圆柱, 银色 -->
      <visual name="${prefix}_nozzle_vis">
        <origin xyz="0 0 0.105" rpy="0 0 0"/>
        <geometry><cylinder radius="0.008" length="0.040"/></geometry>
        <material name="${prefix}_Silver"/>
      </visual>
    </link>

    <!-- 固定关节: Link6 → spray_gun_assembly -->
    <joint name="${prefix}_assembly_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}_gun_assembly"/>
      <!--
        mount_xyz: 适配板中心位置。
        适配板厚 0.020m (z=±0.010)，背面贴合法兰面。
        若法兰面在 Link6 原点，则 mount_xyz.z = 0.010
        使背面 (z=0) 与法兰面齐平。
      -->
      <origin xyz="${mount_xyz}" rpy="${mount_rpy}"/>
    </joint>

    <!-- ===== 喷嘴坐标系 (TF only，+Z = 喷射方向) ===== -->
    <link name="${prefix}_nozzle_frame"/>
    <joint name="${prefix}_nozzle_frame_joint" type="fixed">
      <parent link="${prefix}_gun_assembly"/>
      <child link="${prefix}_nozzle_frame"/>
      <!-- 喷嘴总长: 适配板半厚(0.010) + 枪体(0.075) + 喷嘴(0.040) = 0.125 -->
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
    </joint>

  </xacro:macro>
</robot>
