<?xml version="1.0"?>
<!--
  Gantry V2: Monolithic static frame, local coords only.
  World position applied by spawn_model pose.
  Root link origin = bottom center of gantry frame.
  Four pillars: ±Y = ±width/2, front/rear X = ±depth/2 from center.
-->
<robot name="gantry_v2" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:arg name="width_y" default="1.45"/>
  <xacro:arg name="depth_x" default="0.75"/>
  <xacro:arg name="height" default="1.75"/>
  <xacro:arg name="beam" default="0.04"/>

  <xacro:property name="wy" value="$(arg width_y)"/>
  <xacro:property name="dx" value="$(arg depth_x)"/>
  <xacro:property name="h" value="$(arg height)"/>
  <xacro:property name="b" value="$(arg beam)"/>

  <material name="gantry_gray">
    <color rgba="0.55 0.55 0.55 1"/>
  </material>

  <!-- Root link: origin at bottom center of gantry frame -->
  <link name="gantry_v2_base">
    <inertial>
      <mass value="100.0"/>
      <inertia ixx="50.0" ixy="0" ixz="0" iyy="50.0" iyz="0" izz="50.0"/>
      <origin xyz="0 0 ${h/2}" rpy="0 0 0"/>
    </inertial>

    <!-- Front-left pillar -->
    <visual name="pillar_fl">
      <origin xyz="${-dx/2} ${-wy/2} ${h/2}" rpy="0 0 0"/>
      <geometry><box size="${b} ${b} ${h}"/></geometry>
      <material name="gantry_gray"/>
    </visual>
    <collision name="pillar_fl_col">
      <origin xyz="${-dx/2} ${-wy/2} ${h/2}" rpy="0 0 0"/>
      <geometry><box size="${b} ${b} ${h}"/></geometry>
    </collision>

    <!-- Front-right pillar -->
    <visual name="pillar_fr">
      <origin xyz="${-dx/2} ${wy/2} ${h/2}" rpy="0 0 0"/>
      <geometry><box size="${b} ${b} ${h}"/></geometry>
      <material name="gantry_gray"/>
    </visual>
    <collision name="pillar_fr_col">
      <origin xyz="${-dx/2} ${wy/2} ${h/2}" rpy="0 0 0"/>
      <geometry><box size="${b} ${b} ${h}"/></geometry>
    </collision>

    <!-- Rear-left pillar -->
    <visual name="pillar_rl">
      <origin xyz="${dx/2} ${-wy/2} ${h/2}" rpy="0 0 0"/>
      <geometry><box size="${b} ${b} ${h}"/></geometry>
      <material name="gantry_gray"/>
    </visual>
    <collision name="pillar_rl_col">
      <origin xyz="${dx/2} ${-wy/2} ${h/2}" rpy="0 0 0"/>
      <geometry><box size="${b} ${b} ${h}"/></geometry>
    </collision>

    <!-- Rear-right pillar -->
    <visual name="pillar_rr">
      <origin xyz="${dx/2} ${wy/2} ${h/2}" rpy="0 0 0"/>
      <geometry><box size="${b} ${b} ${h}"/></geometry>
      <material name="gantry_gray"/>
    </visual>
    <collision name="pillar_rr_col">
      <origin xyz="${dx/2} ${wy/2} ${h/2}" rpy="0 0 0"/>
      <geometry><box size="${b} ${b} ${h}"/></geometry>
    </collision>

    <!-- Top beams: 4 sides -->
    <visual name="beam_front">
      <origin xyz="${-dx/2} 0 ${h - b/2}" rpy="0 0 0"/>
      <geometry><box size="${dx} ${b} ${b}"/></geometry>
      <material name="gantry_gray"/>
    </visual>
    <collision name="beam_front_col">
      <origin xyz="${-dx/2} 0 ${h - b/2}" rpy="0 0 0"/>
      <geometry><box size="${dx} ${b} ${b}"/></geometry>
    </collision>

    <visual name="beam_rear">
      <origin xyz="${dx/2} 0 ${h - b/2}" rpy="0 0 0"/>
      <geometry><box size="${dx} ${b} ${b}"/></geometry>
      <material name="gantry_gray"/>
    </visual>
    <collision name="beam_rear_col">
      <origin xyz="${dx/2} 0 ${h - b/2}" rpy="0 0 0"/>
      <geometry><box size="${dx} ${b} ${b}"/></geometry>
    </collision>

    <visual name="beam_left">
      <origin xyz="0 ${-wy/2} ${h - b/2}" rpy="0 0 0"/>
      <geometry><box size="${b} ${wy} ${b}"/></geometry>
      <material name="gantry_gray"/>
    </visual>
    <collision name="beam_left_col">
      <origin xyz="0 ${-wy/2} ${h - b/2}" rpy="0 0 0"/>
      <geometry><box size="${b} ${wy} ${b}"/></geometry>
    </collision>

    <visual name="beam_right">
      <origin xyz="0 ${wy/2} ${h - b/2}" rpy="0 0 0"/>
      <geometry><box size="${b} ${wy} ${b}"/></geometry>
      <material name="gantry_gray"/>
    </visual>
    <collision name="beam_right_col">
      <origin xyz="0 ${wy/2} ${h - b/2}" rpy="0 0 0"/>
      <geometry><box size="${b} ${wy} ${b}"/></geometry>
    </collision>

    <!-- Base plates -->
    <visual name="foot_fl">
      <origin xyz="${-dx/2} ${-wy/2} 0.01" rpy="0 0 0"/>
      <geometry><box size="0.25 0.15 0.02"/></geometry><material name="gantry_gray"/>
    </visual>
    <visual name="foot_fr">
      <origin xyz="${-dx/2} ${wy/2} 0.01" rpy="0 0 0"/>
      <geometry><box size="0.25 0.15 0.02"/></geometry><material name="gantry_gray"/>
    </visual>
    <visual name="foot_rl">
      <origin xyz="${dx/2} ${-wy/2} 0.01" rpy="0 0 0"/>
      <geometry><box size="0.25 0.15 0.02"/></geometry><material name="gantry_gray"/>
    </visual>
    <visual name="foot_rr">
      <origin xyz="${dx/2} ${wy/2} 0.01" rpy="0 0 0"/>
      <geometry><box size="0.25 0.15 0.02"/></geometry><material name="gantry_gray"/>
    </visual>
  </link>

  <gazebo><static>true</static></gazebo>
</robot>
