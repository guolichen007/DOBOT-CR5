<?xml version="1.0"?>
<launch>
  <!-- CR5 Spray Demo V2: fixed CR5 + gantry + object + 3 static cameras -->
  <arg name="gui" default="false"/>
  <arg name="headless" default="false"/>
  <arg name="paused" default="false"/>
  <arg name="object_type" default="flat_panel" doc="flat_panel|cylinder_part|asymmetric_part_v2"/>
  <arg name="camera_profile" default="vm" doc="vm|quality"/>

  <!-- ===== Generate Descriptions ===== -->

  <!-- CR5 with anchored base -->
  <param name="robot_description"
    command="$(find xacro)/xacro $(find cr5_spray_sim)/urdf/cr5_sim.urdf.xacro"/>

  <!-- Gantry V2: static monolithic -->
  <param name="gantry_v2_description"
    command="$(find xacro)/xacro $(find cr5_spray_sim)/urdf/gantry_v2.xacro"/>

  <!-- Object V2: static fixed workpiece -->
  <param name="object_v2_description"
    command="$(find xacro)/xacro $(find cr5_spray_sim)/urdf/object_v2.xacro
             object_type:=$(arg object_type)"/>

  <!-- Camera descriptions (generated by Python node) -->
  <param name="camera_profile" value="$(arg camera_profile)"/>

  <!-- ===== Start Gazebo ===== -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="paused" value="$(arg paused)"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="headless" value="$(arg headless)"/>
  </include>

  <!-- ===== Spawn Models ===== -->

  <!-- CR5 -->
  <node name="spawn_cr5" pkg="gazebo_ros" type="spawn_model"
    args="-urdf -param robot_description -model cr5_robot -x 0 -y 0 -z 0"
    respawn="false" output="screen"/>

  <!-- CR5 controllers -->
  <rosparam file="$(find cr5_spray_sim)/config/cr5_gazebo_controllers.yaml" command="load"/>
  <node name="cr5_controller_spawner" pkg="controller_manager" type="spawner"
    args="joint_state_controller arm_controller"
    respawn="false" output="screen"/>

  <!-- Robot state publisher (for CR5 TF only) -->
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher"
    respawn="false" output="screen">
    <param name="publish_frequency" value="30.0"/>
    <remap from="robot_description" to="robot_description"/>
  </node>

  <!-- Gantry V2: spawn at world position from scene_v2.yaml -->
  <node name="spawn_gantry_v2" pkg="gazebo_ros" type="spawn_model"
    args="-urdf -param gantry_v2_description -model gantry_v2 -x 0.78 -y 0 -z 0"
    respawn="false" output="screen"/>

  <!-- Object V2: spawn at world position from scene_v2.yaml -->
  <node name="spawn_object_v2" pkg="gazebo_ros" type="spawn_model"
    args="-urdf -param object_v2_description -model spray_object -x 0.72 -y 0 -z 0.88"
    respawn="false" output="screen"/>

  <!-- Three static cameras with look-at -->
  <node name="spawn_cameras_v2" pkg="cr5_spray_sim"
    type="spawn_cameras_v2.py" output="screen">
    <param name="camera_profile" value="$(arg camera_profile)"/>
  </node>

  <!-- Object yaw via set_model_state (no ros_control!) -->
  <node name="object_yaw_v2" pkg="cr5_spray_sim"
    type="object_yaw_v2.py" output="screen"/>

  <!-- Dynamic object TF (follows yaw changes) -->
  <node name="object_pose_tf" pkg="cr5_spray_sim"
    type="object_pose_tf_v2.py" output="screen"/>

</launch>
