<?xml version="1.0"?>
<launch>
  <!-- CR5 Industrial Spray Cell V3 -->
  <arg name="gui" default="false"/>
  <arg name="headless" default="false"/>
  <arg name="paused" default="false"/>
  <arg name="object_type" default="automotive_fender_panel"
       doc="automotive_fender_panel|cabinet_door_panel|bumper_corner_panel|geometry_debug_part"/>
  <arg name="camera_profile" default="vm" doc="vm|quality"/>

  <!-- ===== Generate Descriptions ===== -->

  <!-- CR5 with anchored base -->
  <param name="robot_description"
    command="$(find xacro)/xacro $(find cr5_spray_sim)/urdf/cr5_sim.urdf.xacro"/>

  <!-- U-Cell Frame: open-front industrial station -->
  <param name="u_cell_description"
    command="$(find xacro)/xacro $(find cr5_spray_sim)/urdf/u_cell_frame.xacro"/>

  <!-- Camera Pedestals (front-left, front-right) -->
  <param name="pedestal_fl_description"
    command="$(find xacro)/xacro $(find cr5_spray_sim)/urdf/camera_pedestal.xacro"/>

  <param name="pedestal_fr_description"
    command="$(find xacro)/xacro $(find cr5_spray_sim)/urdf/camera_pedestal.xacro"/>

  <!-- Rotary Hanger -->
  <param name="rotary_hanger_description"
    command="$(find xacro)/xacro $(find cr5_spray_sim)/urdf/rotary_hanger.xacro"/>

  <!-- Workpiece V3 (mesh-based) -->
  <param name="workpiece_v3_description"
    command="$(find xacro)/xacro $(find cr5_spray_sim)/urdf/workpiece_v3.xacro
             object_type:=$(arg object_type)"/>

  <!-- ===== Start Gazebo with Industrial World ===== -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="paused" value="$(arg paused)"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="headless" value="$(arg headless)"/>
    <arg name="world_name" value="$(find cr5_spray_sim)/worlds/cr5_industrial_spray_cell.world"/>
  </include>

  <!-- ===== Spawn Models ===== -->

  <!-- CR5 -->
  <node name="spawn_cr5" pkg="gazebo_ros" type="spawn_model"
    args="-urdf -param robot_description -model cr5_robot -x 0 -y 0 -z 0"
    respawn="false" output="screen"/>

  <!-- CR5 controllers -->
  <rosparam file="$(find cr5_spray_sim)/config/cr5_gazebo_controllers.yaml" command="load"/>
  <node name="cr5_controller_spawner" pkg="controller_manager" type="spawner"
    args="joint_state_controller arm_controller"
    respawn="false" output="screen"/>

  <!-- Robot state publisher -->
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher"
    respawn="false" output="screen">
    <param name="publish_frequency" value="30.0"/>
    <remap from="robot_description" to="robot_description"/>
  </node>

  <!-- U-Cell Frame -->
  <node name="spawn_u_cell" pkg="gazebo_ros" type="spawn_model"
    args="-urdf -param u_cell_description -model u_cell_frame -x 1.00 -y 0 -z 0"
    respawn="false" output="screen"/>

  <!-- Camera Pedestal Front-Left -->
  <node name="spawn_pedestal_fl" pkg="gazebo_ros" type="spawn_model"
    args="-urdf -param pedestal_fl_description -model pedestal_fl -x 0.15 -y -0.78 -z 0"
    respawn="false" output="screen"/>

  <!-- Camera Pedestal Front-Right -->
  <node name="spawn_pedestal_fr" pkg="gazebo_ros" type="spawn_model"
    args="-urdf -param pedestal_fr_description -model pedestal_fr -x 0.15 -y 0.78 -z 0"
    respawn="false" output="screen"/>

  <!-- Rotary Hanger -->
  <node name="spawn_rotary_hanger" pkg="gazebo_ros" type="spawn_model"
    args="-urdf -param rotary_hanger_description -model rotary_hanger -x 0.60 -y 0 -z 1.68"
    respawn="false" output="screen"/>

  <!-- Workpiece V3 -->
  <node name="spawn_workpiece_v3" pkg="gazebo_ros" type="spawn_model"
    args="-urdf -param workpiece_v3_description -model spray_workpiece -x 0.60 -y 0 -z 0.94"
    respawn="false" output="screen"/>

  <!-- Three spherical cameras with pedestals -->
  <node name="spawn_cameras_v3" pkg="cr5_spray_sim"
    type="spawn_cameras_v3.py" output="screen">
    <param name="camera_profile" value="$(arg camera_profile)"/>
  </node>

  <!-- Object yaw via set_model_state -->
  <node name="object_yaw_v3" pkg="cr5_spray_sim"
    type="object_yaw_v2.py" output="screen">
    <param name="object_model" value="spray_workpiece"/>
    <param name="object_x" value="0.60"/>
    <param name="object_y" value="0.0"/>
    <param name="object_z" value="0.94"/>
  </node>

  <!-- Dynamic object TF -->
  <node name="object_pose_tf" pkg="cr5_spray_sim"
    type="object_pose_tf_v2.py" output="screen">
    <param name="object_model" value="spray_workpiece"/>
  </node>

</launch>
